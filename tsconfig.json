{
  "compilerOptions": {
    "target": "ES2022",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,

    "ignoreDeprecations": "6.0"
  }
}

